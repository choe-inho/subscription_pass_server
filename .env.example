# ─────────────────────────────────────────────
# subscription_pass_server — 환경변수 템플릿
# · 로컬: 이 파일을 복사해서 .env 로 이름 변경 후 값 채우기
# · Railway: 아래 키들을 Variables 탭에 1:1 로 주입
# ─────────────────────────────────────────────


# ① 공공데이터포털 API 인증키 (청약홈 API)
#   발급: https://www.data.go.kr 에서 "국토교통부_주택분양정보" 등 신청
#   실제 키 1개를 3곳에 동일하게 넣어도 됩니다 (현재 구조 기준)
PUBLIC_DATA_API_KEY=
PUBLIC_DATA_API_KEY_CMPET=
PUBLIC_DATA_API_KEY_STAT=


# ② Supabase (RLS 우회를 위해 반드시 SERVICE_ROLE_KEY 사용)
#   Supabase 대시보드 > Project Settings > API > service_role (secret)
#   ⚠️  이 키는 DB 전체 접근 권한이 있습니다. 절대 공개 저장소에 커밋 금지.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=


# ③ Firebase Admin SDK — FCM 푸시 발송용
#   Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"
#   다운로드한 JSON 파일 "전체 내용"을 한 줄로 만들어 넣습니다.
#   Railway 에서는 멀티라인 그대로 붙여넣어도 되지만, 줄바꿈이 포함되면
#   JSON.parse 에서 private_key 의 \n 이 깨질 수 있으므로 아래 팁 참고:
#
#   ▸ macOS:  cat service-account.json | tr -d '\n' | pbcopy
#     (한 줄로 만들어 클립보드로 복사)
#   ▸ 또는 JSON 안에 "\\n" 으로 된 private_key 는 그대로 두면 정상
FIREBASE_SERVICE_ACCOUNT_JSON=


# ④ FCM Android 채널 ID (앱과 동일해야 함)
FCM_CHANNEL_ID=subscription_pass_channel


# ⑤ 수집 파이프라인 튜닝
COLLECT_PAGE_SIZE=100
MAX_PAGES=30
REQUEST_DELAY_MS=300
LOG_LEVEL=info


# ⑥ 서버 런타임
#   Railway 에서는 PORT 가 자동 주입되므로 비워두거나 생략 가능
PORT=3000

#   배포 직후 즉시 1회 파이프라인을 돌려 동작을 확인하려면 true.
#   운영 안정화 후 false 로 바꾸면 cron 일정대로만 실행됩니다.
RUN_ON_START=false


# ⑦ (선택) RevenueCat 웹훅 인증
#   v1.0 무료 BM 에서는 미사용. v1.2 에서 활성화할 때만 설정
REVENUECAT_WEBHOOK_SECRET=
